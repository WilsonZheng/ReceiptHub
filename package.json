  "version": "1.0.0",
  "description": "Personal invoice/receipt manager PWA — local-first, GitHub-synced, Gemini AI extraction, NZ GST aware, bilingual. Zero backend.",
  "homepage": "https://wilsonzheng.github.io/ReceiptHub/",
